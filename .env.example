# ============================================
# Botpoison Configuration
# ============================================
# Client-side public key (visible in browser)
# Get your keys at: https://botpoison.com/dashboard
PUBLIC_BOTPOISON_PUBLIC_KEY=pb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server-side secret key (NEVER expose to client)
BOTPOISON_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Formspark Configuration
# ============================================
# Your Formspark form ID
# Get it from: https://dashboard.formspark.io/
PUBLIC_FORMSPARK_FORM_ID=xxxxxxxxxxxxxxxxx
