---
import Galleries from "@/components/galleries/Galleries.astro";
/**
 * /galeries – Gallery index page.
 *
 * Fetches all galleries from Sanity at build time (static output)
 * and passes them to the <Galleries> section component.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchSanity } from "@/lib/sanityFetch";
import { GALLERIES_LIST_QUERY } from "@/lib/sanityQueries";
import type { GalleryListItem } from "@/types/galleries";

// ── Data fetching (build-time) ───────────────────────────────────────
const galleryList = (await fetchSanity<GalleryListItem[]>(GALLERIES_LIST_QUERY)) ?? [];

// ── SEO ──────────────────────────────────────────────────────────────
const description =
  "Parcourez les galeries de peintures de Viviane Barbin — portraits, paysages de Bourgogne et œuvres de voyage au pastel et à l'acrylique.";

const jsonLdNodes = [
  {
    "@type": "CollectionPage",
    "@id": "https://viviane-barbin-peintre.fr/galeries#webpage",
    url: "https://viviane-barbin-peintre.fr/galeries",
    name: "Galeries de peintures — Viviane Barbin",
    description,
    inLanguage: "fr-FR",
    isPartOf: { "@id": "https://viviane-barbin-peintre.fr/#website" },
    about: { "@id": "https://viviane-barbin-peintre.fr/#person" },
    breadcrumb: {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Accueil",
          item: "https://viviane-barbin-peintre.fr/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Galeries",
          item: "https://viviane-barbin-peintre.fr/galeries",
        },
      ],
    },
  },
];
---

<BaseLayout
  title="Galeries de peintures - Viviane Barbin"
  description={description}
  jsonLdNodes={jsonLdNodes}
>
  <Galleries title="Galeries" subtitle="Le cœur de mon atelier" galleries={galleryList} />
</BaseLayout>
