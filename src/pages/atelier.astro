---
import Workshop from "@/components/workshop/Workshop.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const description =
  "Découvrez l'atelier de Viviane Barbin à Talon, en Bourgogne nivernaise. Cours de peinture, partage de techniques au pastel et à l'acrylique. Chambre d'hôtes pour prolonger votre séjour.";

const jsonLdNodes = [
  {
    "@type": "WebPage",
    "@id": "https://viviane-barbin-peintre.fr/atelier#webpage",
    url: "https://viviane-barbin-peintre.fr/atelier",
    name: "Atelier et Chambre d'hôtes à Talon — Viviane Barbin",
    description,
    inLanguage: "fr-FR",
    isPartOf: { "@id": "https://viviane-barbin-peintre.fr/#website" },
    about: { "@id": "https://viviane-barbin-peintre.fr/#person" },
    breadcrumb: {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Accueil",
          item: "https://viviane-barbin-peintre.fr/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "L'atelier",
          item: "https://viviane-barbin-peintre.fr/atelier",
        },
      ],
    },
  },
];
---

<BaseLayout
  title="Atelier et Chambre d'hôtes à Talon - Viviane Barbin"
  description={description}
  jsonLdNodes={jsonLdNodes}
>
  <Workshop />
</BaseLayout>
